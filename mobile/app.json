{
  "expo": {
    "name": "QRetrieve",
    "slug": "qretrieve",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "qretrieve",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf7f2"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "QRetrieve needs camera access to scan QR codes and take photos of found items.",
        "NSLocationWhenInUseUsageDescription": "QRetrieve needs location to help return found items to their owners."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#faf7f2",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.arsh.io.qretrieve"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sharing",
      "expo-font",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "QRetrieve needs camera to scan QR codes."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "QRetrieve needs location to report where items were found."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "QRetrieve needs photo access to upload item photos."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f3aab49-1b40-443c-8628-2650fdc5a54e"
      }
    }
  }
}
